# IDE
.idea/
*.iml
*.ipr
*.iws

# Gradle
.gradle/
build/

# Kotlin / Java artifacts
*.class
*.jar
*.war
*.ear

# Re-include Gradle wrapper jar
!**/gradle/wrapper/gradle-wrapper.jar

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
*.swp
*~

# Environment
.env
.env.*

# Jolli / Claude
.jolli/
.claude/
.kiro/
.gemini/
.agents/
.cursor/
.codex/
.opencode/
.devin/
# Claude MCP server config — written per-worktree with an absolute local path
# (jolli install → registerMcpInClaude), so it must never be committed.
.mcp.json
.DS_Store
.idea/
*.iml
**/dist/
**/coverage/
**/node_modules/
**/*.vsix
.superpowers/

# Generated codicon assets (copied from node_modules at build time)
vscode/assets/codicons/

# Generated knowledge-graph viz assets (copied from cli/src/graph/assets at build time)
vscode/assets/graph/

# Local pre-PR review state (per-developer scratch)
.claude/review-findings/

# Personal notes
notes.md

# claude-plugin ships these as part of the plugin package, but they are caught by
# broad ignores above (.mcp.json at repo root; SKILL.md in the user's global
# gitignore). Re-include them so the plugin is committed complete.
!/claude-plugin/plugins/**/.mcp.json
!/claude-plugin/plugins/**/SKILL.md
